# ATS Resume Optimizer — Environment Configuration
# Copy this file to .env and fill in your values, or run: npm run setup

# Required: Your Google Gemini API key
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: Gemini model to use (auto-detected by npm run setup)
# Examples: gemini-2.5-flash, gemini-2.5-pro, gemini-2.0-flash
GEMINI_MODEL=gemini-2.5-flash
